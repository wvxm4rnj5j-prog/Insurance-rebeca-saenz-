  document.getElementById('modulos-count').textContent = completados + '/' + totalModulos + ' m√≥dulos';
  document.getElementById('modulos-pct').textContent = Math.round((completados/totalModulos)*100) + '%';
  document.getElementById('modulos-bar').style.width = Math.round((completados/totalModulos)*100) + '%';
  document.getElementById('academia-pts').textContent = completados * 10;
  document.getElementById('leads-banner').style.display = completados >= 7 ? 'block' : 'none';

  for (let i = 1; i <= totalModulos; i++) {
    const done = modulosCompletados.includes(i);
    const btn = document.createElement('button');
    btn.style.cssText = `width:52px;height:52px;border-radius:50%;border:none;cursor:pointer;font-size:13px;font-weight:700;transition:all 0.2s;background:${done?'linear-gradient(135deg,#c9a84c,#b89a3e)':'rgba(26,42,74,0.08)'};color:${done?'#1a2a4a':'#aab'}`;
    btn.textContent = done ? 'ūüŹÖ' : i;
    btn.title = 'M√≥dulo ' + i;
    btn.onclick = () => toggleModulo(i);
    grid.appendChild(btn);
  }
}

function toggleModulo(n) {
  const idx = modulosCompletados.indexOf(n);
  if (idx > -1) modulosCompletados.splice(idx, 1);
  else modulosCompletados.push(n);
  renderModulos();
}

