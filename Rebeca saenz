  document.getElementById('mod-progreso-bar').style.width = Math.round((completados/modulosData.length)*100) + '%';

  modulosData.forEach((mod, i) => {
    // M√≥dulo disponible solo si el anterior est√° completado (o es el primero)
    const desbloqueado = i === 0 || modulosData[i-1].completado;
    const disponible = !!mod.url && desbloqueado;

    const btn = document.createElement('button');
