let currentQ = 0;
const answers = [];

function startQuiz() {
  currentQ = 0;
  answers.length = 0;
  renderQuestion();
}

function renderQuestion() {
  const q = questions[currentQ];
  const total = questions.length;

  document.getElementById('q-badge').textContent = `Pregunta ${currentQ+1} de ${total}`;
  document.getElementById('progress-fill').style.width = `${((currentQ+1)/total)*100}%`;
  document.getElementById('q-text').textContent = q.q;

  // Section divider
  const secWrap = document.getElementById('q-section-wrap');
  if (q.section) {
    secWrap.style.display = 'block';
    document.getElementById('q-section').textContent = q.section;
  } else {
    secWrap.style.display = 'none';
  }

  // Options
  const container = document.getElementById('q-options');
  container.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const letters = ['A','B','C','D'];
    const btn = document.createElement('button');
    btn.className = 'q-option' + (answers[currentQ] === i ? ' selected' : '');
    btn.innerHTML = `<span class="opt-letter">${letters[i]})</span><span>${opt}</span>`;
    btn.onclick = () => selectAnswer(i);
    container.appendChild(btn);
  });

  // Nav
  const nav = document.getElementById('quiz-nav');
  const isLast = currentQ === total - 1;

  if (isLast) {
    nav.innerHTML = `
      <button class="nav-back" onclick="prevQuestion()">‚Üź Atr√°s</button>
      <button class="finish-btn ${answers[currentQ]!==undefined?'enabled':''}" id="finish-btn" onclick="finishQuiz()">Ver mi resultado ‚Üí</button>
    `;
  } else {
    nav.innerHTML = `
      <button class="nav-back" id="nav-back" onclick="prevQuestion()">‚Üź Atr√°s</button>
      <button class="nav-next ${answers[currentQ]!==undefined?'enabled':''}" id="nav-next" onclick="nextQuestion()">Siguiente ‚Üí</button>
    `;
  }

  if (currentQ === 0) {
    const backBtn = document.getElementById('nav-back');
    if (backBtn) backBtn.style.visibility = 'hidden';
  }
}

function selectAnswer(idx) {
  answers[currentQ] = idx;
  renderQuestion();
}

function nextQuestion() {
  if (answers[currentQ] === undefined) return;
  if (currentQ < questions.length - 1) { currentQ++; renderQuestion(); }
}

function prevQuestion() {
  if (currentQ > 0) { currentQ--; renderQuestion(); }
  else { goTo('screen-paso1'); }
}

function finishQuiz() {
  if (answers[currentQ] === undefined) return;
  // Tally DISC scores
  const tally = {D:0, I:0, S:0, C:0};
  answers.forEach((ans, qi) => {
    if (ans !== undefined && questions[qi]) {
      tally[questions[qi].scores[ans]]++;
    }
  });
  userData.discType = Object.keys(tally).reduce((a,b) => tally[a]>=tally[b]?a:b);
  // Go to video screen first
  document.getElementById('vid-greeting').textContent =
    userData.name ? `¬°Felicidades, ${userData.name}!` : '¬°Felicidades!';
  // Build Calendly link with prefilled data
  const calendlyBase = 'https://calendly.com/insurancesaenzffl/consulta';
